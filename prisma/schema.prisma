generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TuViChart {
  id        String   @id @default(cuid())
  label     String
  birthDate Json
  birthHour Int
  gender    String
  chartData Json
  createdAt DateTime @default(now())
}

model DailyHoroscope {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  zodiac    String   // ty, suu, dan, mao, thin, ti, ngo, mui, than, dau, tuat, hoi
  content   Json     // DailyHoroscope object
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, zodiac], name: "date_zodiac")
  @@index([date])
}

model DailyCalendar {
  id        String   @id @default(cuid())
  date      DateTime @db.Date @unique
  lunarData Json
  dayInfo   Json
  createdAt DateTime @default(now())

  @@index([date])
}
